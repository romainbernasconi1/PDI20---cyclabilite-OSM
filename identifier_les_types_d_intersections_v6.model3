      <Option value="remplissage du champ &quot;prio_début&quot;" name="component_description" type="QString"/>
      <Option value="39" name="component_height" type="double"/>
      <Option value="1929" name="component_pos_x" type="double"/>
      <Option value="1272.5" name="component_pos_y" type="double"/>
      <Option value="200" name="component_width" type="double"/>
      <Option name="dependencies" type="List">
        <Option type="Map">
